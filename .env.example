# my-insane-claude-workflow configuration
#
# claude-workflow does not need Gemini, DeepSeek, OpenAI, or Anthropic API keys
# in the normal local setup. It uses Claude Code auth plus `codex login`.
#
# Put your real values in ~/.ultrathink.env (loaded automatically) or a local
# .env in the project you launch from. Parent-process env vars always win.

# --- Main session (stays on Anthropic, never routed to Codex) ---
ULTRATHINK_GATEWAY_MAIN_MODEL_ID=claude-opus-4-8

# --- Routed workflow subagents (Codex gpt-5.5) ---
ULTRATHINK_GATEWAY_SUBAGENT_REASONING_EFFORT=xhigh
ULTRATHINK_GATEWAY_CODEX_REASONING_EFFORT=xhigh

# --- Optional overrides ---
# ULTRATHINK_GATEWAY_HOST=127.0.0.1
# ULTRATHINK_GATEWAY_PORT=0            # 0 = OS-assigned free port (multi-folder safe)
# ULTRATHINK_GATEWAY_CODEX_COMMAND=codex
# ULTRATHINK_GATEWAY_CODEX_MODEL=gpt-5.5
# ULTRATHINK_GATEWAY_CODEX_VERBOSITY=low
# ULTRATHINK_GATEWAY_CODEX_SANDBOX=workspace-write
# ULTRATHINK_GATEWAY_CODEX_APPROVAL_POLICY=never
# CLAUDE_WORKFLOW_DISPLAY_ROUTED_MODEL=false   # show raw Claude model ids in the UI
