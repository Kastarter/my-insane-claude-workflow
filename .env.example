# Claude Workflow local configuration
#
# Copy selected values into a project .env or ~/.claude-workflow.env.
# Existing ~/.ultrathink.env files are still loaded for compatibility.

# Main Claude Code model. The default is the Fable 5 1m-context variant.
# ULTRATHINK_GATEWAY_MAIN_MODEL_ID=claude-fable-5[1m]
# ULTRATHINK_GATEWAY_MAIN_PROVIDER=anthropic
# ULTRATHINK_GATEWAY_MAIN_UPSTREAM_MODEL=claude-fable-5[1m]
# ULTRATHINK_GATEWAY_MAIN_REASONING_EFFORT=
# ULTRATHINK_GATEWAY_ANTHROPIC_PASSTHROUGH_MODELS=claude-fable-5*

# Workflow/subagent model exposed to Claude Code and routed to Codex.
# ULTRATHINK_GATEWAY_SUBAGENT_MODEL_ID=claude-sonnet-4-7
# ULTRATHINK_GATEWAY_SUBAGENT_UPSTREAM_MODEL=gpt-5.5
# ULTRATHINK_GATEWAY_SUBAGENT_REASONING_EFFORT=medium
# ULTRATHINK_GATEWAY_SUBAGENT_VERBOSITY=high
# CLAUDE_WORKFLOW_DISPLAY_ROUTED_MODEL=true
# CLAUDE_WORKFLOW_SUBAGENT_MODEL_ID=codex-gpt-5.5-medium-via-claude-sonnet-4-7

# Claude Code permission behavior. Default is true.
# CLAUDE_WORKFLOW_SKIP_PERMISSIONS=false

# Local gateway bind. Leave port unset or set 0 for one dynamic port per launch.
# ULTRATHINK_GATEWAY_HOST=127.0.0.1
# ULTRATHINK_GATEWAY_PORT=0
# ULTRATHINK_GATEWAY_SHARED_SECRET=change_me

# Codex app-server route. ULTRATHINK_GATEWAY_CODEX_COMMAND is only the executable,
# not "codex app-server"; the gateway appends app-server itself.
# ULTRATHINK_GATEWAY_CODEX_ENABLED=true
# ULTRATHINK_GATEWAY_CODEX_COMMAND=codex
# ULTRATHINK_GATEWAY_CODEX_CWD=/absolute/path/to/project
# ULTRATHINK_GATEWAY_CODEX_SANDBOX=workspace-write
# ULTRATHINK_GATEWAY_CODEX_APPROVAL_POLICY=never
# ULTRATHINK_GATEWAY_CODEX_MODEL=gpt-5.5
# ULTRATHINK_GATEWAY_CODEX_REASONING_EFFORT=low
# ULTRATHINK_GATEWAY_CODEX_VERBOSITY=low
# Maximum estimated tokens sent to Codex in any single gateway input. This
# bounds fresh-thread transcript bootstraps. Set 0 to disable.
# ULTRATHINK_GATEWAY_CODEX_INPUT_MAX_TOKENS=256000
# Standalone gateway default is disabled. If unset, claude-workflow defaults
# this to 70% of its Codex input ceiling so Codex can compact before the
# gateway recycles the session.
# ULTRATHINK_GATEWAY_CODEX_AUTO_COMPACT_TOKEN_LIMIT=0
# ULTRATHINK_GATEWAY_CODEX_AUTO_COMPACT_TOKEN_LIMIT_SCOPE=body_after_prefix
# Maximum text bytes returned from one Claude tool_result to a Codex dynamic
# tool call. This mirrors Codex native tool-output truncation. Set 0 to disable.
# ULTRATHINK_GATEWAY_CODEX_TOOL_RESULT_MAX_BYTES=10000
# ULTRATHINK_GATEWAY_CODEX_IDLE_TIMEOUT_MS=600000
# ULTRATHINK_GATEWAY_CODEX_FORK_IDLE_TIMEOUT_MS=30000
# ULTRATHINK_GATEWAY_CODEX_MAX_SESSIONS=16

# Anthropic passthrough. For local Claude Code OAuth usage, leave the shared
# secret unset and the gateway forwards Claude's inbound bearer token upstream.
# If ULTRATHINK_GATEWAY_SHARED_SECRET is set, configure a static Anthropic key.
# ULTRATHINK_GATEWAY_ANTHROPIC_API_KEY=your_anthropic_api_key
# ULTRATHINK_GATEWAY_ANTHROPIC_BASE_URL=https://api.anthropic.com
# ULTRATHINK_GATEWAY_ANTHROPIC_VERSION=2023-06-01

# Refusal fallback. When set, Fable/Mythos-family passthrough requests opt into
# Anthropic's server-side refusal fallback (beta server-side-fallback-2026-06-01):
# a safety-classifier decline (stop_reason: refusal) is transparently re-served by
# this model in the same call. If Anthropic rejects the param, the gateway retries
# once without it, so the option can never break requests. Unset = off.
# ULTRATHINK_GATEWAY_REFUSAL_FALLBACK=claude-opus-4-8

# Optional direct OpenAI-compatible route, mostly for tests and compatibility.
# ULTRATHINK_GATEWAY_OPENAI_API_KEY=your_openai_api_key
# ULTRATHINK_GATEWAY_OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek route. Set ULTRATHINK_GATEWAY_MAIN_PROVIDER=deepseek to launch the
# requested main Claude model id while resolving it to DeepSeek V4 Pro.
# ULTRATHINK_GATEWAY_DEEPSEEK_API_KEY=your_deepseek_api_key
# ULTRATHINK_GATEWAY_DEEPSEEK_BASE_URL=https://api.deepseek.com
# ULTRATHINK_GATEWAY_DEEPSEEK_MODEL=deepseek-v4-pro
# ULTRATHINK_GATEWAY_DEEPSEEK_REASONING_EFFORT=max
# DeepSeek thinking mode keeps tools enabled but omits tool_choice for compatibility.
# Set ULTRATHINK_THINKING_LEVEL=OFF to send thinking.type=disabled and omit reasoning_effort.

# GLM route. Set ULTRATHINK_GATEWAY_MAIN_PROVIDER=glm to launch the requested
# main Claude model id while resolving it to Z.ai GLM 5.2.
# ULTRATHINK_GATEWAY_GLM_API_KEY=your_zai_api_key
# ULTRATHINK_GATEWAY_GLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
# ULTRATHINK_GATEWAY_GLM_MODEL=glm-5.2
# ULTRATHINK_GATEWAY_GLM_REASONING_EFFORT=max
# ZAI_API_KEY is also accepted as the GLM API key. GLM thinking defaults to
# thinking.type=enabled, clear_thinking=false, and reasoning_effort=max.
# Set ULTRATHINK_THINKING_LEVEL=OFF to disable GLM thinking.

# Explicit route map overrides. Exact keys win before wildcard keys.
# ULTRATHINK_GATEWAY_ROUTE_MAP_JSON='{"claude-sonnet-4-7":{"provider":"codex","model":"gpt-5.5","sandbox":"workspace-write","approvalPolicy":"never","reasoningEffort":"medium","verbosity":"high","displayName":"Claude Sonnet 4.7 via Codex"},"claude-fable-5*":{"provider":"deepseek","model":"deepseek-v4-pro","reasoningEffort":"max","displayName":"Fable 5 via DeepSeek V4 Pro"},"glm-5.2[1m]":{"provider":"glm","model":"glm-5.2","reasoningEffort":"max","displayName":"GLM 5.2"}}'
# Set this explicitly when route-map entries are wildcard-only and a client uses /v1/models.
# ULTRATHINK_GATEWAY_EXPOSED_MODELS=claude-fable-5[1m]

# Optional tracing.
# ULTRATHINK_GATEWAY_TRACE_DIR=/tmp/claude-workflow-gateway-trace

# Corporate proxy support for gateway upstream HTTP requests. Proxy URLs must
# use http:// or https://. claude-workflow adds its local gateway host to
# NO_PROXY/no_proxy for the child Claude process when a proxy is configured.
# HTTPS_PROXY=http://proxy.example.com:8080
# HTTP_PROXY=http://proxy.example.com:8080
# ALL_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1
