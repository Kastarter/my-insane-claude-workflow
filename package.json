{
  "name": "my-insane-claude-workflow",
  "version": "0.1.0",
  "description": "Claude Code launcher with a local Anthropic-compatible gateway for Codex-backed workflow subagents.",
  "type": "module",
  "bin": {
    "claude-workflow": "js/cli/claude-workflow.js",
    "claude-workflow-gateway": "scripts/claude-workflow-daemon.sh"
  },
  "scripts": {
    "start": "node js/cli/claude-workflow.js",
    "start:gateway": "node js/anthropic-gateway-index.js",
    "daemon": "bash scripts/claude-workflow-daemon.sh start",
    "daemon:status": "bash scripts/claude-workflow-daemon.sh status",
    "daemon:stop": "bash scripts/claude-workflow-daemon.sh stop",
    "daemon:log": "bash scripts/claude-workflow-daemon.sh log",
    "check": "node scripts/check-syntax.mjs",
    "test": "npm run -s check && npm run -s test:gateway && npm run -s test:onboarding",
    "test:gateway": "node test/gateway.test.js && node test/codex-provider-hardening.test.js && node test/daemon-observability.test.js && node --test test/security-hardening.test.js",
    "test:onboarding": "node --test test/onboarding.test.js",
    "test:package": "node test/package-install-smoke.test.js",
    "prepack": "npm run -s check",
    "prepublishOnly": "npm test && npm run test:package",
    "test:live:glm": "node test/glm/live-glm-gateway.js"
  },
  "keywords": [
    "claude-code",
    "codex",
    "workflow",
    "gateway",
    "anthropic"
  ],
  "author": "Kastarter",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kastarter/my-insane-claude-workflow.git"
  },
  "homepage": "https://github.com/Kastarter/my-insane-claude-workflow#readme",
  "bugs": {
    "url": "https://github.com/Kastarter/my-insane-claude-workflow/issues"
  },
  "dependencies": {
    "dotenv": "16.3.1",
    "express": "5.1.0",
    "undici": "6.27.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "js",
    "scripts",
    ".env.example",
    "CHANGELOG.md",
    "SECURITY.md",
    "SUPPORT.md",
    "docs",
    "README.md",
    "LICENSE"
  ]
}
